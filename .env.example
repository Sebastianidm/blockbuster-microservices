# ==============================================================================
# CONFIGURACIÓN GENERAL BLOCKBUSTER MICROSERVICES
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Configuración de PostgreSQL (Local Container)
# ------------------------------------------------------------------------------
# Se utilizará para inicializar el contenedor postgres-db y crear las BDs de negocio:
# - users_db
# - transactions_db
# - catalog_db
DB_USERNAME=neondb_owner
DB_PASSWORD=localpassword
DB_PORT=5432

# ------------------------------------------------------------------------------
# 2. Configuración de MongoDB (Local Container)
# ------------------------------------------------------------------------------
# Se utilizará para inicializar el contenedor mongo-db y su base de datos:
# - notifications_db
MONGO_USERNAME=admin_blockbuster
MONGO_PASSWORD=localpassword
MONGO_PORT=27017

# ------------------------------------------------------------------------------
# 3. Puertos de Servicios Core (Core Infrastructure)
# ------------------------------------------------------------------------------
EUREKA_PORT=8761
GATEWAY_PORT=8080

# ------------------------------------------------------------------------------
# 4. Seguridad y Comunicación Interna (Compartido)
# ------------------------------------------------------------------------------
JWT_SECRET=Esta_es_una_clave_secreta_super_larga_y_segura_para_el_proyecto_blockbuster_2026
JWT_EXPIRATION=86400000
INTERNAL_API_KEY=change-this-internal-api-key

# ------------------------------------------------------------------------------
# NOTAS DE INTEGRACIÓN HÍBRIDA (WSL / Local Host)
# ------------------------------------------------------------------------------
# Si ejecutas los servicios de negocio en local (fuera de Docker) pero las BDs 
# y la infraestructura en Docker, configura el archivo .env de cada microservicio 
# con los siguientes valores de conexión:
#
# Para Users:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/users_db
#
# Para Catalog:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/catalog_db
#
# Para Transactions:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/transactions_db
#
# Para Notifications:
# SPRING_MONGODB_URI=mongodb://admin_blockbuster:localpassword@localhost:27017/notifications_db?authSource=admin
#
# Ojo de Tech Lead: Si el api-gateway de Docker no puede enrutar tus servicios 
# locales, en tu .env local de cada microservicio configura:
# EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
# EUREKA_INSTANCE_IP_ADDRESS=host.docker.internal
# ==============================================================================
